# Environment Variables Template
# 복사하여 사용: cp .env.example .env
# 주의: 아래 값들은 실제 운영/테스트 키로 교체해야 정상 동작합니다.

# Firebase Project (Firebase Console > Project settings > General)
FIREBASE_PROJECT_ID=ganengile
FIREBASE_AUTH_DOMAIN=ganengile.web.app
FIREBASE_DATABASE_URL=https://ganengile-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_STORAGE_BUCKET=ganengile.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# OAuth Providers (필요 시만 사용)
# Google OAuth (Google 로그인에 필요)
# 발급 방법: 아래 가이드 참조
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=your_google_client_secret_here_optional

# Kakao OAuth (카카오 로그인에 필요)
EXPO_PUBLIC_KAKAO_APP_KEY=your_kakao_app_key_here

# Public APIs (Optional)
SEOUL_SUBWAY_API_KEY=your_seoul_subway_api_key_here
KOREAIL_API_KEY=your_koreail_api_key_here
INCHEON_SUBWAY_API_KEY=your_incheon_subway_api_key_here

# App Configuration
APP_NAME=가는길에
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
ENABLE_DEBUG=false

# Development
NODE_ENV=production

# Seoul Fare API (data.go.kr)
# URL은 고정, SERVICE_KEY만 교체
EXPO_PUBLIC_SEOUL_FARE_API_URL=https://apis.data.go.kr/B553766/fare
EXPO_PUBLIC_SEOUL_FARE_SERVICE_KEY=YOUR_DATA_GO_KR_SERVICE_KEY

# Firebase (App)
# 아래 항목들은 앱 런타임에서 직접 사용되므로 반드시 설정해야 합니다.
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID
