# Environment Variables Template
# Copy to `.env` and replace every placeholder before production deployment.

# Firebase (App)
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# Firebase (base project metadata)
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_AUTH_DOMAIN=YOUR_FIREBASE_AUTH_DOMAIN
FIREBASE_DATABASE_URL=YOUR_FIREBASE_DATABASE_URL
FIREBASE_STORAGE_BUCKET=YOUR_FIREBASE_STORAGE_BUCKET
FIREBASE_MESSAGING_SENDER_ID=YOUR_FIREBASE_MESSAGING_SENDER_ID
FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID
FIREBASE_MEASUREMENT_ID=YOUR_FIREBASE_MEASUREMENT_ID

# OAuth / Verification
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_CLIENT_SECRET=
EXPO_PUBLIC_KAKAO_APP_KEY=
EXPO_PUBLIC_PASS_VERIFY_URL=
EXPO_PUBLIC_KAKAO_VERIFY_URL=
EXPO_PUBLIC_PASS_TEST_MODE=true

# Public transport / fare APIs
SEOUL_SUBWAY_API_KEY=
KOREAIL_API_KEY=
INCHEON_SUBWAY_API_KEY=
EXPO_PUBLIC_SEOUL_FARE_API_URL=https://apis.data.go.kr/B553766/fare
EXPO_PUBLIC_SEOUL_FARE_SERVICE_KEY=
EXPO_PUBLIC_SEOUL_FARE_CACHE_ONLY=true
SEOUL_FARE_API_URL=https://apis.data.go.kr/B553766/fare
SEOUL_FARE_SERVICE_KEY=

# Locker / KRIC
EXPO_PUBLIC_KRIC_LOCKER_API_URL=https://openapi.kric.go.kr/openapi/convenientInfo/stationLocker
EXPO_PUBLIC_KRIC_SERVICE_KEY=
EXPO_PUBLIC_KRIC_RAIL_OPR_ISTT_CD=S1
EXPO_PUBLIC_LOCKER_API_URL=
EXPO_PUBLIC_LOCKER_API_KEY=

# Maps (Naver)
# App screens use the static map proxy by default.
EXPO_PUBLIC_MAP_PROVIDER=naver-static
EXPO_PUBLIC_NAVER_MAP_ENABLED=true
EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=YOUR_NAVER_MAP_CLIENT_ID
EXPO_PUBLIC_NAVER_STATIC_MAP_PROXY_URL=https://us-central1-YOUR_FIREBASE_PROJECT_ID.cloudfunctions.net/naverStaticMapProxy

# Dynamic web map
# Switch provider to `naver-web` when enabling the browser SDK.
EXPO_PUBLIC_NAVER_WEB_MAP_ENABLED=false
EXPO_PUBLIC_NAVER_MAP_WEB_CLIENT_ID=

# Road-name address search (Juso)
EXPO_PUBLIC_JUSO_SEARCH_PROXY_URL=https://us-central1-YOUR_FIREBASE_PROJECT_ID.cloudfunctions.net/jusoAddressSearchProxy

# Server-only secrets
NAVER_MAP_CLIENT_ID=YOUR_NAVER_MAP_CLIENT_ID
NAVER_MAP_CLIENT_SECRET=YOUR_NAVER_MAP_CLIENT_SECRET
JUSO_API_KEY=YOUR_JUSO_CONFIRM_KEY

# App metadata
APP_NAME=가는길에
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1
NODE_ENV=production
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true
ENABLE_DEBUG=false
