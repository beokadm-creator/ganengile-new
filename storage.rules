rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ==================== Helper Functions ====================
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
             && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // ==================== User Files ====================

    match /users/{userId}/{allPaths=**} {
      // 사용자 전용 파일은 본인만 읽고 쓸 수 있음
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /photos/{userId}/{allPaths=**} {
      // 배송 요청용 물품 사진은 업로드한 사용자만 쓸 수 있음
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ==================== Public Files ====================

    match /public/{allPaths=**} {
      // 공개적으로 접근 가능한 파일
      allow read: if true;
      allow write: if false; // 쓰기는 불가
    }

    // ==================== Delivery Photos ====================

    match /pickup-photos/{deliveryId}/{allPaths=**} {
      allow read: if request.auth != null;
      // 이미지이고 10MB 이하일 때만 업로드 허용
      allow write: if request.auth != null && isValidImage();
    }

    match /delivery-photos/{deliveryId}/{allPaths=**} {
      allow read: if request.auth != null;
      // 이미지이고 10MB 이하일 때만 업로드 허용
      allow write: if request.auth != null && isValidImage();
    }

    // ==================== Profile Photos ====================

    match /profile-photos/{userId}/{allPaths=**} {
      // 프로필 사진은 공개
      allow read: if true;
      // 본인만 업로드 가능
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ==================== ID Photos (Verification) ====================

    match /id-photos/{userId}/{allPaths=**} {
      // 신분증 사진은 본인만 읽기 가능
      allow read: if request.auth != null && request.auth.uid == userId;
      // 본인만 업로드 가능
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ==================== Chat Photos ====================

    match /chat-photos/{chatId}/{allPaths=**} {
      // 채팅 사진은 참여자만 읽기 가능
      allow read: if request.auth != null;
      // 참여자만 업로드 가능
      allow write: if request.auth != null;
    }

    // ==================== Locker Photos ====================

    match /locker-photos/{lockerId}/{allPaths=**} {
      // 락커 사진은 공개
      allow read: if true;
      // 인증된 사용자만 업로드 가능
      allow write: if request.auth != null;
    }
  }
}
