rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==================== Helper Functions ====================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function getRequestDoc(requestId) {
      return get(/databases/$(database)/documents/requests/$(requestId));
    }

    function getDeliveryDoc(deliveryId) {
      return get(/databases/$(database)/documents/deliveries/$(deliveryId));
    }

    function isRequestParticipantById(requestId) {
      return isAuthenticated() && (
        isAdmin() ||
        isOwner(getRequestDoc(requestId).data.requesterId) ||
        isOwner(getRequestDoc(requestId).data.requesterUserId) ||
        isOwner(getRequestDoc(requestId).data.matchedGillerId)
      );
    }

    function isDeliveryParticipantById(deliveryId) {
      return isAuthenticated() && (
        isAdmin() ||
        isOwner(getDeliveryDoc(deliveryId).data.gillerId) ||
        isOwner(getDeliveryDoc(deliveryId).data.gllerId) ||
        isOwner(getDeliveryDoc(deliveryId).data.requesterId) ||
        isOwner(getDeliveryDoc(deliveryId).data.requesterUserId)
      );
    }

    function isChatRoomParticipant(roomId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants.user1.userId == request.auth.uid ||
        get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants.user2.userId == request.auth.uid
      );
    }

    // ==================== Config Collections (Read-Only, Public) ====================

    match /config_stations/{stationId} {
      allow read: if true;  // Public config data
      allow write: if false;
    }

    match /config_travel_times/{timeId} {
      allow read: if true;  // Public config data
      allow write: if false;
    }

    match /config_express_trains/{trainId} {
      allow read: if true;  // Public config data
      allow write: if false;
    }

    match /config_congestion/{congestionId} {
      allow read: if true;  // Public config data
      allow write: if false;
    }

    match /config_algorithm_params/{documentId} {
      allow read: if true;  // Public config data
      allow write: if false;
    }

    // ==================== Consent Templates (Read-Only, Authenticated) ====================

    match /consentTemplates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK로만 쓰기 (관리자 API 경유)
    }

    // ==================== Integration Config (비민감 설정만 — testMode 등) ====================
    // API 키는 admin_settings에만 보관. 앱은 여기서 testMode만 읽음.

    match /config_integrations/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Admin SDK로만 쓰기
    }

    match /config_operational/{docId} {
      allow read: if docId == 'recipient_contact_privacy' || isAuthenticated();
      allow write: if false;
    }

    // ==================== Users Collection ====================

    match /users/{userId} {
      // 읽기: 인증된 사용자는 개별 문서 조회(get)만 가능, 목록 조회(list)는 불가
      allow get: if isAuthenticated();
      allow list: if false;
      
      // 쓰기: 본인만
      allow create, update: if isOwner(userId);
      
      // 삭제: 본인만
      allow delete: if isOwner(userId);

      // ==================== Profile Subcollection ====================
      
      match /profile/{profileId} {
        // 읽기: 본인만
        allow read: if isOwner(userId);
        
        // 생성: 본인만
        allow create: if isOwner(userId);
        
        // 업데이트: 본인만
        allow update: if isOwner(userId);
        
        // 삭제: 본인만
        allow delete: if isOwner(userId);

        match /saved_addresses/{addressId} {
          allow read, create, update, delete: if isOwner(userId);
        }

        match /recent_addresses/{addressId} {
          allow read, create, update, delete: if isOwner(userId);
        }
      }

      // ==================== Verification Subcollection ====================
      
      match /verification/{verificationId} {
        // 읽기: 본인만
        allow read: if isOwner(userId);
        
        // 생성: 본인만
        allow create: if isOwner(userId);
        
        // 업데이트: 본인만 (또는 관리자)
        allow update: if isOwner(userId);
        
        // 삭제: 시스템만
        allow delete: if false;
      }
    }

    // ==================== Giller Applications ====================

    match /giller_applications/{applicationId} {
      // 본인 신청 내역 또는 관리자만 조회
      allow read: if isAuthenticated() &&
                  (isAdmin() || isOwner(resource.data.userId));

      // 본인 신청만 생성 허용
      allow create: if isAuthenticated() &&
                    request.resource.data.userId == request.auth.uid;

      // 관리자가 심사 상태 변경 가능
      allow update: if isAdmin();

      // 삭제는 관리자만
      allow delete: if isAdmin();
    }

    // ==================== Wallet / Payment Collections ====================

    match /point_transactions/{transactionId} {
      allow read: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.userId));

      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.userId);

      allow update, delete: if isAdmin();
    }

    match /withdraw_requests/{withdrawRequestId} {
      allow read: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.userId));

      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.userId);

      allow update, delete: if isAdmin();
    }

    match /wallet_ledgers/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow write: if false;
    }

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         isOwner(resource.data.reporterId) ||
         isOwner(resource.data.userId));

      allow create: if isAuthenticated() &&
        (isOwner(request.resource.data.reporterId) ||
         isOwner(request.resource.data.userId));

      allow update: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.reporterId) || isOwner(resource.data.userId));

      allow delete: if false;
    }

    match /dispute_history/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         isOwner(resource.data.userId) ||
         isOwner(resource.data.gillerId) ||
         isOwner(resource.data.gllerId));

      allow create: if isAuthenticated() &&
        (isOwner(request.resource.data.userId) ||
         isOwner(request.resource.data.gillerId) ||
         isOwner(request.resource.data.gllerId));

      allow update, delete: if isAdmin();
    }

    match /settlements/{settlementId} {
      allow read: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.gillerId) || isOwner(resource.data.userId));

      allow create, update, delete: if isAdmin();
    }

    // ==================== Routes Collection ====================

    match /routes/{routeId} {
      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 생성: 인증된 사용자 (본인의 userId로 생성)
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);

      // 업데이트: 본인만
      allow update: if isOwner(resource.data.userId);

      // 삭제: 본인만
      allow delete: if isOwner(resource.data.userId);
    }

    // ==================== Beta1 Collections ====================

    match /request_drafts/{requestDraftId} {
      allow read: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.requesterUserId));

      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.requesterUserId);

      allow update, delete: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.requesterUserId));
    }

    match /ai_analyses/{aiAnalysisId} {
      allow read: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.requesterUserId));

      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.requesterUserId);

      allow update: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.requesterUserId));

      allow delete: if false;
    }

    match /pricing_quotes/{pricingQuoteId} {
      allow read: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.requesterUserId));

      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.requesterUserId);

      allow update: if isAuthenticated() &&
        (isAdmin() || isOwner(resource.data.requesterUserId));

      allow delete: if false;
    }

    match /delivery_legs/{deliveryLegId} {
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(resource.data.requestId) ||
         isDeliveryParticipantById(resource.data.deliveryId));

      allow create: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(request.resource.data.requestId) ||
         isDeliveryParticipantById(request.resource.data.deliveryId));

      allow update: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(resource.data.requestId) ||
         isDeliveryParticipantById(resource.data.deliveryId));

      allow delete: if false;
    }

    match /handover_events/{handoverEventId} {
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(resource.data.requestId) ||
         isDeliveryParticipantById(resource.data.deliveryId));

      allow create, update: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(request.resource.data.requestId) ||
         isDeliveryParticipantById(request.resource.data.deliveryId));

      allow delete: if false;
    }

    match /missions/{missionId} {
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(resource.data.requestId) ||
         isDeliveryParticipantById(resource.data.deliveryId) ||
         isOwner(resource.data.assignedGillerUserId));

      allow create: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(request.resource.data.requestId) ||
         isDeliveryParticipantById(request.resource.data.deliveryId));

      allow update: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(resource.data.requestId) ||
         isDeliveryParticipantById(resource.data.deliveryId) ||
         isOwner(resource.data.assignedGillerUserId));

      allow delete: if false;
    }

    match /mission_bundles/{missionBundleId} {
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(resource.data.requestId) ||
         isDeliveryParticipantById(resource.data.deliveryId));

      allow create, update: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(request.resource.data.requestId) ||
         isDeliveryParticipantById(request.resource.data.deliveryId));

      allow delete: if false;
    }

    match /actor_selection_decisions/{decisionId} {
      allow read: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(resource.data.requestId) ||
         (resource.data.deliveryId != null && isDeliveryParticipantById(resource.data.deliveryId)));

      allow create, update: if isAuthenticated() &&
        (isAdmin() ||
         isRequestParticipantById(request.resource.data.requestId) ||
         (request.resource.data.deliveryId != null && isDeliveryParticipantById(request.resource.data.deliveryId)));

      allow delete: if false;
    }

    // ==================== Requests Collection ====================

    match /requests/{requestId} {
      // 읽기: 요청자, 매칭된 길러, 또는 공개 상태인 대기 중(pending) 요청
      allow read: if isAuthenticated() &&
                  (resource.data.status == 'pending' ||
                   isOwner(resource.data.requesterId) ||
                   isOwner(resource.data.matchedGillerId));

      // 생성: 인증된 사용자 + 본인 requesterId 바인딩
      allow create: if isAuthenticated()
                    && request.resource.data.requesterId == request.auth.uid;

      // 쓰기: 요청자 또는 매칭된 길러
      // + pending/matched 요청을 길러가 최초 수락(accepted)하는 전환 허용
      allow update: if isAuthenticated() &&
                    (isOwner(resource.data.requesterId) ||
                     isOwner(resource.data.matchedGillerId) ||
                     (
                       (resource.data.status == 'pending' || resource.data.status == 'matched') &&
                       request.resource.data.status == 'accepted' &&
                       request.resource.data.matchedGillerId == request.auth.uid
                     ));

      // 삭제: 요청자만
      allow delete: if isOwner(resource.data.requesterId);
    }

    // ==================== Matches Collection ====================

    match /matches/{matchId} {
      // 읽기: 관련된 사용자 (requester, gller/giller)
      allow read: if isAuthenticated() &&
                  (isOwner(resource.data.userId) ||
                   isOwner(resource.data.gllerId) ||
                   isOwner(resource.data.gillerId));

      // 쓰기: 시스템 또는 본인
      allow write: if isOwner(resource.data.userId);

      // 삭제: 시스템만
      allow delete: if false;
    }

    match /transfer_matches/{matchId} {
      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 쓰기: 본인(userId)만
      allow create, update: if isOwner(request.resource.data.userId) || isOwner(resource.data.userId);

      // 삭제: 시스템만
      allow delete: if false;
    }

    // ==================== Deliveries Collection ====================

    match /deliveries/{deliveryId} {
      // 읽기: gller(요청자) 또는 giller(길러)
      allow read: if isAuthenticated() &&
                  (isOwner(resource.data.gllerId) ||
                   isOwner(resource.data.gillerId) ||
                   isOwner(resource.data.requesterId));

      // 생성: 요청자(gller)가 배송 요청 시 생성, 또는 길러가 수락 시 생성
      allow create: if isAuthenticated() &&
                    (request.resource.data.requesterId == request.auth.uid ||
                     request.resource.data.gillerId == request.auth.uid);

      // 수정: 요청자, 해당 배송 길러 본인, 또는 관리자
      allow update: if isAuthenticated() &&
                    (isOwner(resource.data.gllerId) ||
                     isOwner(resource.data.gillerId) ||
                     isOwner(resource.data.requesterId) ||
                     isAdmin());

      // 삭제: 시스템만
      allow delete: if false;
    }

    // ==================== Ratings Collection ====================

    match /ratings/{ratingId} {
      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 쓰기: 본인(fromUserId)만
      allow write: if isOwner(resource.data.fromUserId);

      // 삭제: 시스템만
      allow delete: if false;
    }

    // ==================== Penalties Collection ====================

    match /penalties/{penaltyId} {
      // 읽기: 본인만
      allow read: if isOwner(resource.data.userId);

      // 쓰기: 시스템만 (Admin SDK)
      allow write: if false;

      // 삭제: 시스템만
      allow delete: if false;
    }

    // ==================== Chats Collection ====================

    match /chats/{chatId} {
      // 읽기: 참여자만
      allow read: if isAuthenticated() &&
                  (request.auth.uid in resource.data.participants);

      // 쓰기: 참여자만
      allow write: if isAuthenticated() &&
                   (request.auth.uid in resource.data.participants);

      // 삭제: 참여자 모두 or 시스템
      allow delete: if false;
    }

    // DEPRECATED: chatRooms 하위 컬렉션으로 이전됨. 기존 chats 컬렉션 호환성 유지용.
    match /chats/{chatId}/messages/{messageId} {
      // 읽기: 채팅방 참여자만
      allow read: if isChatRoomParticipant(chatId);

      // 생성: 참여자만 (발신자 검증)
      allow create: if isChatRoomParticipant(chatId) &&
                    request.resource.data.senderId == request.auth.uid;

      // 업데이트: 불가
      allow update: if false;

      // 삭제: 발신자 본인만
      allow delete: if isChatRoomParticipant(chatId) &&
                    isOwner(resource.data.senderId);
    }

    // ==================== ChatRooms Collection ====================

    // ==================== B2B Collections ====================

    match /b2b_requests/{requestId} {
      // 읽기: B2B 회사 또는 길러
      allow read: if isAuthenticated() &&
                  (isOwner(resource.data.companyId) ||
                   request.auth.uid in resource.data.availableGillers);

      // 쓰기: B2B 회사만
      allow write: if isOwner(resource.data.companyId);

      // 삭제: B2B 회사만
      allow delete: if isOwner(resource.data.companyId);
    }

    match /b2b_gillers/{gillerId} {
      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 쓰기: 본인(gller/giller)만
      allow write: if isOwner(gillerId);

      // 삭제: 본인만
      allow delete: if isOwner(gillerId);
    }

    match /b2b_settlements/{settlementId} {
      // 읽기: B2B 회사만
      allow read: if isOwner(resource.data.companyId);

      // 쓰기: 시스템만 (Admin SDK)
      allow write: if false;

      // 삭제: 시스템만
      allow delete: if false;
    }

    match /b2b_deliveries/{deliveryId} {
      // 읽기: B2B 회사 또는 길러
      allow read: if isAuthenticated() &&
                  (isOwner(resource.data.companyId) ||
                   (resource.data.gllerId != null && isOwner(resource.data.gllerId)));

      // 쓰기: B2B 회사만
      allow write: if isOwner(resource.data.companyId);

      // 삭제: B2B 회사만
      allow delete: if isOwner(resource.data.companyId);
    }

    match /b2b_tax_invoices/{invoiceId} {
      // 읽기: B2B 회사 또는 관리자
      allow read: if isAuthenticated() &&
                  (isOwner(resource.data.companyId) || isAdmin());

      // 쓰기: 관리자만 (Admin SDK)
      allow write: if isAdmin();

      // 삭제: 관리자만
      allow delete: if isAdmin();
    }

    // ==================== Lockers Collection ====================

    match /lockers/{lockerId} {
      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 쓰기: 시스템만 (Admin SDK)
      allow write: if false;

      // 삭제: 시스템만
      allow delete: if false;
    }

    match /non_subway_lockers/{lockerId} {
      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 쓰기: 시스템만 (Admin SDK)
      allow write: if false;

      // 삭제: 시스템만
      allow delete: if false;
    }

    // ==================== Auctions Collection ====================

    match /auctions/{auctionId} {
      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 생성: 길러 본인만 (gllerId 바인딩)
      allow create: if isAuthenticated() &&
                    request.resource.data.gllerId == request.auth.uid;

      // 업데이트: 생성자만
      allow update: if isOwner(resource.data.gllerId);

      // 삭제: 생성자만
      allow delete: if isOwner(resource.data.gllerId);
    }

    // ==================== Bids Collection ====================

    match /bids/{bidId} {
      // 읽기: 인증된 사용자
      allow read: if isAuthenticated();

      // 생성: 입찰자 본인만 (gllerId 바인딩)
      allow create: if isAuthenticated() &&
                    request.resource.data.gllerId == request.auth.uid;

      // 업데이트: 입찰자만
      allow update: if isOwner(resource.data.gllerId);

      // 삭제: 입찰자만
      allow delete: if isOwner(resource.data.gllerId);
    }

    // ==================== Chat Rooms Collection ====================

    match /chatRooms/{chatRoomId} {
      // 읽기: 참여자만
      allow read: if isAuthenticated() &&
                  (resource.data.participants.user1.userId == request.auth.uid ||
                   resource.data.participants.user2.userId == request.auth.uid);

      // 생성: 인증된 사용자
      allow create: if isAuthenticated();

      // 업데이트: 참여자만
      allow update: if isAuthenticated() &&
                    (resource.data.participants.user1.userId == request.auth.uid ||
                     resource.data.participants.user2.userId == request.auth.uid);

      // 삭제: 참여자만
      allow delete: if isAuthenticated() &&
                    (resource.data.participants.user1.userId == request.auth.uid ||
                     resource.data.participants.user2.userId == request.auth.uid);

      // 메시지 하위 컬렉션
      match /messages/{messageId} {
        // 읽기: 채팅방 참여자만
        allow read: if isAuthenticated() &&
                    ((get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.participants.user1.userId == request.auth.uid) ||
                     (get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.participants.user2.userId == request.auth.uid));

        // 생성: 참여자만
        allow create: if isAuthenticated() &&
                      ((get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.participants.user1.userId == request.auth.uid) ||
                       (get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.participants.user2.userId == request.auth.uid));

        // 업데이트/삭제: 불가
        allow update, delete: if false;
      }
    }
  }
}
