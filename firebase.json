{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "region": "asia-northeast3"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "apphosting": [
    {
      "backendId": "ganengile-admin",
      "rootDir": "admin-web",
      "ignore": [
        "**/node_modules/**",
        "**/.next/**",
        "**/.expo/**",
        "**/.git/**",
        "**/coverage/**",
        "**/dist/**",
        "**/dist-web/**",
        "**/.DS_Store"
      ]
    }
  ]
}
